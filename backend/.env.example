PORT=5000
NODE_ENV=production

# MongoDB Atlas connection string — replace with your actual URI
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/strikz_esports?retryWrites=true&w=majority

# JWT Secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# MUST be at least 64 random characters. Server will refuse to start without this.
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_MINIMUM_64_CHARS

JWT_EXPIRY=24h

# Your production domain for CORS (comma-separated if multiple)
ALLOWED_ORIGINS=https://www.strikzesports.in,https://strikzesports.in

SUPPORT_EMAIL=support@strikzesports.com
PARTNER_EMAIL=partners@strikzesports.com

# Email provider — configure ONE of the following:
# Option A: Brevo (Recommended — free 300 emails/day)
BREVO_API_KEY=your-brevo-api-key-here
BREVO_FROM_EMAIL=noreply@strikzesports.com
EMAIL_FROM_NAME=Strikz Esports

# Option B: Resend
# RESEND_API_KEY=your-resend-api-key-here
# RESEND_FROM_EMAIL=noreply@strikzesports.com

# Google OAuth Client ID — create at https://console.cloud.google.com/
# Server will refuse to start without this.
GOOGLE_CLIENT_ID=REPLACE_WITH_YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com
